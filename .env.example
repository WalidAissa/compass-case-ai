# Copy to .env and fill in real values. Never commit .env.

# --- LLM ---
OPENAI_API_KEY=sk-...

# Model used for both text and vision extraction paths.
# Switch to gpt-4o-mini during development to save cost.
OPENAI_MODEL=gpt-4o

# --- Resilience ---
# Max attempts before a transient LLM failure becomes a permanent job failure.
LLM_MAX_RETRIES=3

# --- Observability ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Runtime ---
# dev | prod  (affects log format: pretty vs JSON)
APP_ENV=dev
